{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "archive-manifest.schema.json",
  "title": "Monthly Archive Manifest",
  "description": "Manifest file included in monthly archives",
  "type": "object",
  "required": ["archive_month", "created_at", "total_files", "total_rooms", "checksum"],
  "properties": {
    "archive_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Month in YYYY-MM format"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Archive creation timestamp"
    },
    "total_files": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of JSON files archived"
    },
    "total_rooms": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of unique rooms"
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA256 checksum of archive"
    }
  },
  "additionalProperties": false
}
