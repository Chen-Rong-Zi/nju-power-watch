{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "daily-record.schema.json",
  "title": "Daily Electricity Record",
  "description": "Snapshot of electricity data for one room on one specific date",
  "type": "object",
  "required": ["id", "校区", "楼栋", "房间", "宿舍ID", "剩余电量", "timestamp", "success"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Room ID (numeric string)"
    },
    "校区": {
      "type": "string",
      "minLength": 1,
      "description": "Campus name"
    },
    "楼栋": {
      "type": "string",
      "minLength": 1,
      "description": "Building name"
    },
    "房间": {
      "type": "string",
      "minLength": 1,
      "description": "Room name"
    },
    "宿舍ID": {
      "type": "string",
      "minLength": 1,
      "description": "Dormitory ID"
    },
    "学号": {
      "type": "string",
      "description": "Student ID (if applicable)"
    },
    "剩余电量": {
      "type": "string",
      "pattern": "^[0-9]+\\.?[0-9]*度$",
      "description": "Remaining electricity in 度"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of query"
    },
    "success": {
      "type": "boolean",
      "const": true,
      "description": "Query success flag (must be true for valid record)"
    }
  },
  "additionalProperties": false
}
